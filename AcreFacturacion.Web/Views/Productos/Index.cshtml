@model AcreFacturacion.Web.ViewModels.PaginatedList<AcreFacturacion.Web.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Productos</h1>
        <p class="text-muted">Gestión de productos e inventario.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">Nuevo producto</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-10">
        <input type="text"
               name="buscar"
               value="@ViewBag.Buscar"
               class="form-control"
               placeholder="Buscar por nombre o código" />
    </div>

    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            No hay productos registrados.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Codigo</td>
                            <td>@item.Nombre</td>
                            <td>L @item.Precio.ToString("N2")</td>
                            <td>
                                @if (item.Stock < 5)
                                {
                                    <span class="badge bg-danger">@item.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.Stock</span>
                                }
                            </td>
                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-info">
                                        Ver
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning">
                                        Editar
                                    </a>

                                    @if (item.Estado)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#estadoProductoModal"
                                                data-url="@Url.Action("Desactivar", "Productos", new { id = item.Id })"
                                                data-title="Desactivar producto"
                                                data-message="¿Desea desactivar el producto @item.Nombre?"
                                                data-button="Desactivar"
                                                data-button-class="btn-danger">
                                            Desactivar
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-success"
                                                data-bs-toggle="modal"
                                                data-bs-target="#estadoProductoModal"
                                                data-url="@Url.Action("Activar", "Productos", new { id = item.Id })"
                                                data-title="Activar producto"
                                                data-message="¿Desea activar el producto @item.Nombre?"
                                                data-button="Activar"
                                                data-button-class="btn-success">
                                            Activar
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-end">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.PageIndex - 1)"
                   asp-route-buscar="@ViewBag.Buscar">
                    Anterior
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-buscar="@ViewBag.Buscar">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.PageIndex + 1)"
                   asp-route-buscar="@ViewBag.Buscar">
                    Siguiente
                </a>
            </li>
        </ul>
    </nav>
}

<div class="modal fade" id="estadoProductoModal" tabindex="-1" aria-labelledby="estadoProductoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content app-modal">
            <form id="estadoProductoForm" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="estadoProductoModalLabel">
                        Confirmar acción
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body">
                    <p id="estadoProductoMensaje" class="mb-0">
                        ¿Desea continuar?
                    </p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit" id="estadoProductoBoton" class="btn btn-danger">
                        Confirmar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const estadoProductoModal = document.getElementById('estadoProductoModal');

        if (estadoProductoModal) {
            estadoProductoModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;

                const url = button.getAttribute('data-url');
                const title = button.getAttribute('data-title');
                const message = button.getAttribute('data-message');
                const buttonText = button.getAttribute('data-button');
                const buttonClass = button.getAttribute('data-button-class');

                const form = document.getElementById('estadoProductoForm');
                const modalTitle = document.getElementById('estadoProductoModalLabel');
                const modalMessage = document.getElementById('estadoProductoMensaje');
                const confirmButton = document.getElementById('estadoProductoBoton');

                form.setAttribute('action', url);
                modalTitle.textContent = title;
                modalMessage.textContent = message;

                confirmButton.textContent = buttonText;
                confirmButton.className = 'btn ' + buttonClass;
            });
        }
    </script>
}