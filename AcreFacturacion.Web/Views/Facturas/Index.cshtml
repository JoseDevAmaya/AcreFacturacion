@model AcreFacturacion.Web.ViewModels.PaginatedList<AcreFacturacion.Web.Models.Factura>

@{
    ViewData["Title"] = "Facturas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Facturas</h1>
        <p class="text-muted">Listado de facturas emitidas.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nueva factura</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Número</th>
                    <th>Cliente</th>
                    <th>Fecha</th>
                    <th>Subtotal</th>
                    <th>ISV</th>
                    <th>Total</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
               @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No hay facturas registradas.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.NumeroFactura</td>
                            <td>@item.Cliente?.Nombre</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>L @item.Subtotal.ToString("N2")</td>
                            <td>L @item.Isv.ToString("N2")</td>
                            <td><strong>L @item.Total.ToString("N2")</strong></td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Ver</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-end">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.PageIndex - 1)">
                    Anterior
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.PageIndex + 1)">
                    Siguiente
                </a>
            </li>
        </ul>
    </nav>
}