
@model AcreFacturacion.Web.Models.Factura

@{
    ViewData["Title"] = "Detalle de factura";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success no-print">
        @TempData["Success"]
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4 no-print">
    <div>
        <h1 class="mb-1">Factura @Model.NumeroFactura</h1>
        <p class="text-muted mb-0">Comprobante generado por el sistema.</p>
    </div>

    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary" onclick="window.print()">
            Imprimir
        </button>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>

<div class="factura-print-area">
    <div class="invoice-header mb-4">
        <div>
            <h2 class="mb-1">Acre Facturación</h2>
            <p class="text-muted mb-0">Sistema administrativo C# / MySQL</p>
        </div>
        <div class="text-end">
            <h3 class="mb-1">Factura</h3>
            <strong>@Model.NumeroFactura</strong>
        </div>
    </div>

    <div class="card mb-4 invoice-card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h5 class="mb-3">Datos del cliente</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Cliente</dt>
                        <dd class="col-sm-8">@Model.Cliente?.Nombre</dd>

                        <dt class="col-sm-4">Identidad / RTN</dt>
                        <dd class="col-sm-8">@Model.Cliente?.IdentidadRTN</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h5 class="mb-3">Datos de la factura</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Número</dt>
                        <dd class="col-sm-8">@Model.NumeroFactura</dd>

                        <dt class="col-sm-4">Fecha</dt>
                        <dd class="col-sm-8">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Estado</dt>
                        <dd class="col-sm-8">
                            @if (Model.Anulada)
                            {
                                <span class="badge bg-danger">Anulada</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Emitida</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="card invoice-card">
        <div class="card-header bg-white">
            <h5 class="mb-0">Detalle de productos</h5>
        </div>

        <div class="card-body">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-end">Precio</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in Model.Detalles)
                    {
                        <tr>
                            <td>@detalle.Producto?.Nombre</td>
                            <td class="text-center">@detalle.Cantidad</td>
                            <td class="text-end">L @detalle.PrecioUnitario.ToString("N2")</td>
                            <td class="text-end">L @detalle.Subtotal.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row justify-content-end mt-3">
                <div class="col-md-4">
                    <div class="border rounded-3 p-3 bg-light invoice-total-box">
                        <div class="d-flex justify-content-between mb-2">
                            <strong>Subtotal</strong>
                            <span>L @Model.Subtotal.ToString("N2")</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <strong>ISV 15%</strong>
                            <span>L @Model.Isv.ToString("N2")</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between fs-5">
                            <strong>Total</strong>
                            <strong>L @Model.Total.ToString("N2")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="invoice-footer mt-4">
        <p class="mb-0 text-muted">
            Documento generado automáticamente por Acre Facturación.
        </p>
    </div>
</div>