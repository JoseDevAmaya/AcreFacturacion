@model AcreFacturacion.Web.Models.Factura
@using System.Globalization

@{
    ViewData["Title"] = "Detalle de factura";
    var moneda = CultureInfo.InvariantCulture;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success no-print">
        @TempData["Success"]
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4 no-print">
    <div>
        <h1 class="mb-1">Factura @Model.NumeroFactura</h1>
        <p class="text-muted mb-0">Detalle de la factura emitida.</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>

        <button type="button" class="btn btn-primary" onclick="window.print()">
            Imprimir factura
        </button>
    </div>
</div>

<div class="factura-print-area">
    <div class="invoice-header mb-4">
        <div>
            <h2 class="mb-1">Acre Facturación</h2>
            <p class="text-muted mb-0">Sistema administrativo de facturación</p>
        </div>

        <div class="text-end">
            <h3 class="mb-1">Factura</h3>
            <strong>@Model.NumeroFactura</strong>
        </div>
    </div>

    <div class="card mb-4 invoice-card">
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <h5 class="mb-3">Datos de la factura</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-5">Número</dt>
                        <dd class="col-sm-7">@Model.NumeroFactura</dd>

                        <dt class="col-sm-5">Fecha</dt>
                        <dd class="col-sm-7">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-5">Estado</dt>
                        <dd class="col-sm-7">
                            @if (Model.Anulada)
                            {
                                <span class="badge bg-danger">Anulada</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Emitida</span>
                            }
                        </dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h5 class="mb-3">Datos del cliente</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-5">Cliente</dt>
                        <dd class="col-sm-7">@Model.Cliente?.Nombre</dd>

                        <dt class="col-sm-5">Identidad / RTN</dt>
                        <dd class="col-sm-7">@Model.Cliente?.IdentidadRTN</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="card invoice-card">
        <div class="card-header bg-white">
            <h5 class="mb-0">Detalle de productos</h5>
        </div>

        <div class="card-body">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th style="width: 45%;">Producto</th>
                        <th class="text-center" style="width: 15%;">Cantidad</th>
                        <th class="text-end" style="width: 20%;">Precio unitario</th>
                        <th class="text-end" style="width: 20%;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in Model.Detalles)
                    {
                        <tr>
                            <td>@detalle.Producto?.Nombre</td>
                            <td class="text-center">@detalle.Cantidad.ToString("#,##0", moneda)</td>
                            <td class="text-end">L @detalle.PrecioUnitario.ToString("#,##0.00", moneda)</td>
                            <td class="text-end">L @detalle.Subtotal.ToString("#,##0.00", moneda)</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row justify-content-end mt-3">
                <div class="col-md-5 col-lg-4">
                    <div class="border rounded-3 p-3 invoice-total-box">
                        <div class="d-flex justify-content-between mb-2">
                            <strong>Subtotal</strong>
                            <span>L @Model.Subtotal.ToString("#,##0.00", moneda)</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <strong>ISV 15%</strong>
                            <span>L @Model.Isv.ToString("#,##0.00", moneda)</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between fs-5">
                            <strong>Total</strong>
                            <strong>L @Model.Total.ToString("#,##0.00", moneda)</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="invoice-footer mt-4">
        <p class="mb-0 text-muted">
          Comprobante emitido por Acre Facturación.
        </p>
    </div>
</div>