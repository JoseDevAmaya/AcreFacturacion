@model AcreFacturacion.Web.Models.Factura

@{
    ViewData["Title"] = "Detalle de factura";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Factura @Model.NumeroFactura</h1>
        <p class="text-muted">Detalle de la factura emitida.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Cliente</dt>
            <dd class="col-sm-9">@Model.Cliente?.Nombre</dd>

            <dt class="col-sm-3">Identidad / RTN</dt>
            <dd class="col-sm-9">@Model.Cliente?.IdentidadRTN</dd>

            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Total</dt>
            <dd class="col-sm-9"><strong>L @Model.Total.ToString("N2")</strong></dd>
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5>Detalle de productos</h5>

        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detalle in Model.Detalles)
                {
                    <tr>
                        <td>@detalle.Producto?.Nombre</td>
                        <td>@detalle.Cantidad</td>
                        <td>L @detalle.PrecioUnitario.ToString("N2")</td>
                        <td>L @detalle.Subtotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row justify-content-end">
            <div class="col-md-4">
                <table class="table">
                    <tr>
                        <th>Subtotal</th>
                        <td class="text-end">L @Model.Subtotal.ToString("N2")</td>
                    </tr>
                    <tr>
                        <th>ISV 15%</th>
                        <td class="text-end">L @Model.Isv.ToString("N2")</td>
                    </tr>
                    <tr>
                        <th>Total</th>
                        <td class="text-end fw-bold">L @Model.Total.ToString("N2")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>