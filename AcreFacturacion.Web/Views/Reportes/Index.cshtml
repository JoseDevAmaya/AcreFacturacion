@model AcreFacturacion.Web.ViewModels.ReportesViewModel

@{
    ViewData["Title"] = "Reportes";
}

<div class="mb-4">
    <h1 class="mb-0">Reportes</h1>
    <p class="text-muted">Indicadores principales de ventas, clientes e inventario.</p>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Top 5 productos más vendidos</h5>
            </div>
            <div class="card-body">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Producto</th>
                            <th>Cantidad vendida</th>
                            <th>Total vendido</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.TopProductosVendidos.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No hay ventas registradas.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.TopProductosVendidos)
                            {
                                <tr>
                                    <td>@item.Codigo</td>
                                    <td>@item.Nombre</td>
                                    <td>@item.CantidadVendida</td>
                                    <td>L @item.TotalVendido.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Clientes con mayor facturación</h5>
            </div>
            <div class="card-body">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Identidad / RTN</th>
                            <th>Cantidad de facturas</th>
                            <th>Total facturado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ClientesMayorFacturacion.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No hay facturación registrada.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.ClientesMayorFacturacion)
                            {
                                <tr>
                                    <td>@item.Nombre</td>
                                    <td>@item.IdentidadRTN</td>
                                    <td>@item.CantidadFacturas</td>
                                    <td>L @item.TotalFacturado.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Inventario bajo</h5>
                <small class="text-muted">Productos activos con stock menor a 5.</small>
            </div>
            <div class="card-body">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Producto</th>
                            <th>Stock</th>
                            <th>Precio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.InventarioBajo.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No hay productos con inventario bajo.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.InventarioBajo)
                            {
                                <tr>
                                    <td>@item.Codigo</td>
                                    <td>@item.Nombre</td>
                                    <td>
                                        <span class="badge bg-danger">@item.Stock</span>
                                    </td>
                                    <td>L @item.Precio.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>