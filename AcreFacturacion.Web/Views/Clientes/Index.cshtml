@model AcreFacturacion.Web.ViewModels.PaginatedList<AcreFacturacion.Web.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Clientes</h1>
        <p class="text-muted">Gestión de clientes registrados.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nuevo cliente</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-10">
        <input type="text"
               name="buscar"
               value="@ViewBag.Buscar"
               class="form-control"
               placeholder="Buscar por nombre, identidad/RTN o correo" />
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Identidad / RTN</th>
                    <th>Teléfono</th>
                    <th>Correo</th>
                    <th>Fecha registro</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
             @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No hay clientes registrados.
                        </td>
                    </tr>
                }
                else
                {
                foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.IdentidadRTN</td>
                            <td>@item.Telefono</td>
                            <td>@item.Correo</td>
                            <td>@item.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="text-end">
                              <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Ver</a>
<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editar</a>

@if (item.Estado)
{
    <form asp-action="Desactivar" asp-route-id="@item.Id" method="post" class="d-inline">
        <button type="submit"
                class="btn btn-sm btn-outline-danger"
                onclick="return confirm('¿Desea desactivar este cliente?');">
            Desactivar
        </button>
    </form>
}
else
{
    <form asp-action="Activar" asp-route-id="@item.Id" method="post" class="d-inline">
        <button type="submit"
                class="btn btn-sm btn-outline-success"
                onclick="return confirm('¿Desea activar este cliente?');">
            Activar
        </button>
    </form>
}
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-end">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.PageIndex - 1)"
                   asp-route-buscar="@ViewBag.Buscar">
                    Anterior
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-buscar="@ViewBag.Buscar">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.PageIndex + 1)"
                   asp-route-buscar="@ViewBag.Buscar">
                    Siguiente
                </a>
            </li>
        </ul>
    </nav>
}