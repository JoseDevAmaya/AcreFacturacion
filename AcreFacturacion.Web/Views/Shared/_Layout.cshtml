<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Acre Facturación</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AcreFacturacion.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm app-navbar border-bottom box-shadow mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Acre Facturación
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Alternar navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav flex-grow-1 ms-3">
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Clientes" asp-action="Index">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Productos" asp-action="Index">Productos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Facturas" asp-action="Index">Facturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Reportes" asp-action="Index">Reportes</a>
                            </li>
                        </ul>

                        <div class="d-flex align-items-center gap-2 ms-auto">
                            <span class="app-user-chip">
                                @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-primary app-logout-btn">
                                    Cerrar sesión
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <span class="navbar-text app-system-label ms-auto">
                            Sistema administrativo
                        </span>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer border-top text-muted">
        <div class="container">
            &copy; 2026 - Acre Facturación - Sistema C# / MySQL
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/forms-validation.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
